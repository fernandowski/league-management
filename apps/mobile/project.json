{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile",
  "projectType": "application",
  "tags": [
    "scope:mobile",
    "type:app"
  ],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo start"
      }
    },
    "web": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo start --web"
      }
    },
    "build-web": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo export --platform web --output-dir ../../dist/apps/mobile-web"
      },
      "outputs": [
        "{workspaceRoot}/dist/apps/mobile-web"
      ]
    },
    "android": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo start --android"
      }
    },
    "ios": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo start --ios"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx jest --runInBand --config jest.config.js"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo lint"
      }
    }
  }
}
