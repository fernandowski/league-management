{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile",
  "projectType": "application",
  "tags": [
    "scope:web",
    "type:app"
  ],
  "implicitDependencies": [
    "mobile"
  ],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mobile",
        "command": "npx expo start --web -c"
      }
    }
  }
}
